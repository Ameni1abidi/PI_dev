{% extends 'enseignant/dashboard_base.html.twig' %}

{% block title %}Chapitres du Cours{% endblock %}

{% block body %}
<div style="padding:30px; font-family:'Manrope', sans-serif; background-color:#f0f2f5; min-height:100vh;">
  {% for label, messages in app.flashes %}
    {% for message in messages %}
      <div style="margin-bottom:12px; padding:10px 14px; border-radius:10px; font-weight:600;
        background:{% if label == 'success' %}#e8fff0{% elseif label == 'warning' %}#fff7e0{% else %}#ffe9e9{% endif %};
        color:{% if label == 'success' %}#1c6b3a{% elseif label == 'warning' %}#7a5b00{% else %}#8a1f1f{% endif %};">
        {{ message }}
      </div>
    {% endfor %}
  {% endfor %}

  <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:30px;">
    <h2 style="font-size:1.8rem; color:#333;">
      Chapitres du cours : {{ cours ? cours.titre : '' }}
    </h2>

    <a href="{{ cours ? path('app_chapitre_new', {'coursId': cours.id}) : '#' }}"
       style="
           display:inline-block;
           padding:10px 25px;
           background: linear-gradient(90deg, #ff416c, #ff4b2b);
           color:white;
           text-decoration:none;
           border-radius:50px;
           font-weight:700;
           font-size:1rem;
           box-shadow:0 6px 15px rgba(0,0,0,0.2);
           transition:0.3s;
       "
       onmouseover="this.style.transform='translateY(-3px)'; this.style.boxShadow='0 10px 20px rgba(0,0,0,0.25)';"
       onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 6px 15px rgba(0,0,0,0.2)';"
       {% if not cours %}onclick="alert('Veuillez d\'abord selectionner un cours !'); return false;"{% endif %}>
      Ajouter Chapitre
    </a>
  </div>

  {% if chapitres is not empty %}
    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:25px;">
      {% for chapitre in chapitres %}
        <div style="
            background:white;
            border-radius:15px;
            padding:20px;
            box-shadow:0 8px 20px rgba(0,0,0,0.08);
            display:flex;
            flex-direction:column;
            justify-content:space-between;
            transition:0.3s;
        "
        onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 12px 25px rgba(0,0,0,0.15)';"
        onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 8px 20px rgba(0,0,0,0.08)';">

          <div>
            <div style="font-weight:700; font-size:1.2rem; color:#222; margin-bottom:8px;">{{ chapitre.titre }}</div>

            <div style="font-size:0.85rem; color:#555; margin-bottom:12px;">
              Type : <span style="font-weight:600; color:#ff4b2b;">{{ chapitre.typeContenu|capitalize }}</span>
            </div>

            {% if chapitre.typeContenu|lower == 'texte' and chapitre.contenuTexte %}
              <div style="font-size:0.9rem; color:#555; line-height:1.4; max-height:3.5em; overflow:hidden; text-overflow:ellipsis; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical;">
                {{ chapitre.contenuTexte }}
              </div>
            {% elseif chapitre.typeContenu|lower == 'fichier' and chapitre.contenuFichier %}
              <a href="{{ asset('uploads/' ~ chapitre.contenuFichier) }}" target="_blank"
                 style="
                    display:inline-flex;
                    align-items:center;
                    gap:8px;
                    padding:8px 12px;
                    background-color:#007bff;
                    color:white;
                    border-radius:8px;
                    font-weight:600;
                    font-size:0.85rem;
                    text-decoration:none;
                    box-shadow:0 3px 8px rgba(0,0,0,0.15);
                    transition:0.3s;
                 "
                 onmouseover="this.style.backgroundColor='#0056b3';"
                 onmouseout="this.style.backgroundColor='#007bff';">
                Telecharger PDF
              </a>
            {% elseif chapitre.typeContenu|lower == 'video' and chapitre.videoUrl %}
              <a href="{{ chapitre.videoUrl }}" target="_blank"
                 style="display:inline-flex; align-items:center; gap:6px; font-size:0.85rem; color:#17a2b8; font-weight:600; text-decoration:none;">
                Voir la video
              </a>
            {% elseif chapitre.typeContenu|lower == 'devoir' and chapitre.contenuFichier %}
              <a href="{{ asset('uploads/devoirs/' ~ chapitre.contenuFichier) }}" target="_blank"
                 style="display:inline-flex; align-items:center; gap:6px; font-size:0.85rem; color:#ffc107; font-weight:600; text-decoration:none;">
                Devoir a telecharger
              </a>
            {% elseif chapitre.typeContenu|lower == 'exercice_corrige' and chapitre.contenuFichier %}
              <a href="{{ asset('uploads/exercices/' ~ chapitre.contenuFichier) }}" target="_blank"
                 style="display:inline-flex; align-items:center; gap:6px; font-size:0.85rem; color:#28a745; font-weight:600; text-decoration:none;">
                Exercice corrige
              </a>
            {% endif %}

            <div style="font-size:0.8rem; color:#999; margin-top:10px;">
              Ordre: {{ chapitre.ordre }} - Duree : {{ chapitre.dureeEstimee }} min
            </div>
          </div>

          <div style="margin-top:15px; display:flex; flex-wrap:wrap; gap:8px;">
            <a href="{{ path('app_ressource_index', {'chapitre_id': chapitre.id}) }}"
               style="padding:6px 12px; border:1px solid #28a745; color:#28a745; text-decoration:none; border-radius:12px; font-size:0.8rem; font-weight:600;">
              Ressources
            </a>

            <a href="{{ path('app_chapitre_edit', {'id': chapitre.id}) }}"
               style="padding:6px 12px; border:1px solid #007bff; color:#007bff; text-decoration:none; border-radius:12px; font-size:0.8rem; font-weight:600; transition:0.3s;"
               onmouseover="this.style.backgroundColor='#007bff'; this.style.color='white';"
               onmouseout="this.style.backgroundColor='transparent'; this.style.color='#007bff';">
              Modifier
            </a>

            <form method="post" action="{{ path('app_chapitre_delete', {'id': chapitre.id}) }}"
                  onsubmit="return confirm('Voulez-vous vraiment supprimer ce chapitre ?');" style="display:inline;">
              <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ chapitre.id) }}">
              <button type="submit"
                      style="padding:6px 12px; border:1px solid #dc3545; color:#dc3545; background:none; border-radius:12px; font-size:0.8rem; font-weight:600; cursor:pointer; transition:0.3s;"
                      onmouseover="this.style.backgroundColor='#dc3545'; this.style.color='white';"
                      onmouseout="this.style.backgroundColor='transparent'; this.style.color='#dc3545';">
                Supprimer
              </button>
            </form>
          </div>

        </div>
      {% endfor %}
    </div>
  {% else %}
    <div style="text-align:center; margin-top:20px; padding:15px; background-color:#e9ecef; border-radius:10px; font-size:0.9rem; color:#555;">
      Aucun chapitre disponible pour le moment.
    </div>
  {% endif %}

</div>
{% endblock %}
