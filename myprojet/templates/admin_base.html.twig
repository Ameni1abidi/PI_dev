<!DOCTYPE html>
﻿<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon" type="image/svg+xml" href="{{ asset('favicon.svg') }}">
    <title>{% block title %}EduFlex Back Office{% endblock %}</title>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('css/admin.css') }}">
    {% block stylesheets %}{% endblock %}
  </head>
  <body>
    <div class="admin-shell">
      <aside class="admin-sidebar">
        <div class="brand">
          <img class="brand-logo" src="{{ asset('images/eduflex-logo.png') }}" alt="EduFlex">
          <div class="brand-text">
            <div class="brand-name">EduFlex</div>
          </div>
        </div>

        <nav class="nav">
          <a class="nav-link" href="{{ path('app_admin') }}"><span class="nav-icon">🏠</span>Dashboard Admin</a>
          <a class="nav-link" href="{{ path('app_forum_index_context', {'context': 'admin'}) }}"><span class="nav-icon">F</span>Forum</a>
          <a class="nav-link is-active" href="{{ path('app_utilisateur_index') }}"><span class="nav-icon">👥</span>Utilisateurs</a>
          <a class="nav-link" href="#"><span class="nav-icon">🏫</span>Classes</a>
          <a class="nav-link" href="#"><span class="nav-icon">📚</span>Matières</a>
          <a class="nav-link" href="#"><span class="nav-icon">🔐</span>Droits d’accès</a>
          <a class="nav-link" href="#"><span class="nav-icon">📈</span>Statistiques</a>
          <a class="nav-link" href="#"><span class="nav-icon">⚙️</span>Paramètres</a>
          <a class="nav-link" href="{{ path('app_admin') }}"><span class="nav-icon">D</span>Dashboard Admin</a>
          <a class="nav-link" href="{{ path('app_forum_index_context', {'context': 'admin'}) }}"><span class="nav-icon">F</span>Forum</a>
          <a class="nav-link is-active" href="{{ path('app_utilisateur_index') }}"><span class="nav-icon">U</span>Utilisateurs</a>
          <a class="nav-link" href="{{ path('app_admin_classes') }}"><span class="nav-icon">C</span>Classes</a>
          <a class="nav-link" href="{{ path('app_categorie_index') }}"><span class="nav-icon">M</span>Matieres</a>
          <a class="nav-link" href="{{ path('app_admin_access') }}"><span class="nav-icon">A</span>Droits d'acces</a>
          <a class="nav-link" href="{{ path('app_admin_stats') }}"><span class="nav-icon">S</span>Statistiques</a>
          <a class="nav-link" href="{{ path('app_admin_settings') }}"><span class="nav-icon">P</span>Parametres</a>
        </nav>

        <div class="sidebar-card">
          <div class="sidebar-card-title">Actions rapides</div>
          <button class="btn btn-primary" type="button">Créer un cours</button>
          <a class="btn btn-primary" href="{{ path('app_cours_new') }}">Creer un cours</a>
          <a class="btn btn-outline" href="{{ path('app_utilisateur_new') }}">Ajouter un utilisateur</a>
        </div>
      </aside>

      <main class="admin-main">
        <header class="topbar">
          <div>
            <div class="topbar-title">Dashboard Admin</div>
            <div class="topbar-sub">Bienvenue sur EduFlex, Admin</div>
          </div>
          <div class="topbar-actions">
            <button class="chip" type="button">Nouveau rapport</button>
            <a class="chip" href="{{ path('app_admin_stats') }}">Nouveau rapport</a>
            <a class="chip" href="{{ logout_path() }}">Deconnexion</a>
            <div class="avatar">AM</div>
          </div>
        </header>

        {% block body %}{% endblock %}
      </main>
    </div>
  </body>
</html>
