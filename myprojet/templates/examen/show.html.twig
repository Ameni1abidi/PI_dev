{% extends 'crud_base.html.twig' %}

{% block title %}Detail examen{% endblock %}

{% block body %}
  {% set canSendReminder = examen.dateExamen and ('now'|date('U') <= examen.dateExamen|date('U')) %}

  <h1 class="h3 mb-4">Examen #{{ examen.id }}</h1>

  <table class="table table-bordered bg-white">
    <tbody>
      <tr><th>Titre</th><td>{{ examen.titre }}</td></tr>
      <tr>
        <th>Fichier</th>
        <td>
          {% if examen.contenu %}
            <a href="{{ asset('uploads/examens/' ~ examen.contenu) }}" target="_blank">{{ examen.contenu }}</a>
          {% endif %}
        </td>
      </tr>
      <tr><th>Type</th><td>{{ examen.type }}</td></tr>
      <tr><th>Date</th><td>{{ examen.dateExamen ? examen.dateExamen|date('Y-m-d') : '' }}</td></tr>
      <tr><th>Duree</th><td>{{ examen.duree }}</td></tr>
      <tr><th>Cours</th><td>{{ examen.cours ? examen.cours.titre ~ ' (#' ~ examen.cours.id ~ ')' : '' }}</td></tr>
      <tr><th>Enseignant</th><td>{{ examen.enseignant ? examen.enseignant.nom ~ ' (#' ~ examen.enseignant.id ~ ')' : '' }}</td></tr>
    </tbody>
  </table>

  <div class="card mb-3">
    <div class="card-header">Notifications evaluation (Twilio SMS + WhatsApp)</div>
    <div class="card-body">
      <p class="text-muted mb-3">Les numeros sont selectionnes automatiquement par le systeme.</p>
      <div class="d-flex flex-wrap gap-2">
        <button type="button" class="btn btn-primary" data-notify="created">Notifier creation</button>
        {% if canSendReminder %}
          <button type="button" class="btn btn-warning" data-notify="reminder">Notifier rappel</button>
        {% endif %}
        <button type="button" class="btn btn-success" data-notify="results">Notifier resultats</button>
      </div>
      <div id="notify-output" class="alert alert-secondary mt-3 mb-0" role="alert">
        Aucune notification envoyee.
      </div>
    </div>
  </div>

  <div class="card mb-3">
    <div class="card-header">IA Qualite d evaluation</div>
    <div class="card-body">
      <p class="text-muted mb-3">Analyse automatique: clarte, difficulte, couverture et recommandations.</p>
      <button type="button" class="btn btn-dark" id="btn-ai-quality">Analyser la qualite</button>
      <div id="ai-quality-output" class="alert alert-secondary mt-3 mb-0" role="alert">
        Aucune analyse lancee.
      </div>
      <div id="ai-quality-details" class="mt-3"></div>
    </div>
  </div>

  <div class="d-flex align-items-center gap-2">
    <a class="btn btn-link" href="{{ path('app_examen_index') }}">Retour a la liste</a>
    <a class="btn btn-outline-primary" href="{{ path('app_examen_edit', {'id': examen.id}) }}">Editer</a>
    {{ include('examen/_delete_form.html.twig', {examen: examen}) }}
  </div>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script>
    (function () {
      var routes = {
        created: "{{ path('app_eval_notify_created', {'id': examen.id}) }}",
        reminder: "{{ path('app_eval_notify_reminder', {'id': examen.id}) }}",
        results: "{{ path('app_eval_notify_results', {'id': examen.id}) }}",
        aiQuality: "{{ path('app_examen_ai_quality', {'id': examen.id}) }}"
      };

      var output = document.getElementById('notify-output');
      var buttons = document.querySelectorAll('[data-notify]');
      var aiButton = document.getElementById('btn-ai-quality');
      var aiOutput = document.getElementById('ai-quality-output');
      var aiDetails = document.getElementById('ai-quality-details');

      function setOutput(message, level) {
        output.className = 'alert mt-3 mb-0 alert-' + level;
        output.textContent = message;
      }

      function setAiOutput(message, level) {
        aiOutput.className = 'alert mt-3 mb-0 alert-' + level;
        aiOutput.textContent = message;
      }

      function renderAiList(title, items, cssClass) {
        if (!items || !items.length) {
          return '';
        }
        var html = '<div class="mt-2"><strong>' + title + '</strong><ul class="mb-0 mt-1">';
        items.forEach(function (item) {
          html += '<li class="' + cssClass + '">' + item + '</li>';
        });
        html += '</ul></div>';
        return html;
      }

      buttons.forEach(function (button) {
        button.addEventListener('click', function () {
          var type = button.getAttribute('data-notify');
          var url = routes[type];

          button.disabled = true;
          setOutput('Envoi en cours...', 'secondary');

          fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({})
          })
            .then(function (response) {
              return response.json().then(function (body) {
                return { status: response.status, body: body };
              });
            })
            .then(function (result) {
              var sent = result.body && result.body.result && result.body.result.sent;
              var baseMessage = result.body && result.body.result && result.body.result.message
                ? result.body.result.message
                : (result.body && result.body.message ? result.body.message : 'Reponse recue.');
              var count = result.body && typeof result.body.recipients_count === 'number'
                ? result.body.recipients_count
                : 0;
              var finalMessage = baseMessage + ' Destinataires: ' + count + '.';
              var isSuccess = typeof sent === 'boolean' ? sent : (result.status >= 200 && result.status < 300);
              setOutput(finalMessage, isSuccess ? 'success' : 'danger');
            })
            .catch(function (error) {
              setOutput('Erreur: ' + String(error), 'danger');
            })
            .finally(function () {
              button.disabled = false;
            });
        });
      });

      if (aiButton) {
        aiButton.addEventListener('click', function () {
          aiButton.disabled = true;
          aiDetails.innerHTML = '';
          setAiOutput('Analyse IA en cours...', 'secondary');

          fetch(routes.aiQuality, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({})
          })
            .then(function (response) {
              return response.json().then(function (body) {
                return { status: response.status, body: body };
              });
            })
            .then(function (result) {
              var analysis = result.body && result.body.analysis ? result.body.analysis : null;
              if (!analysis) {
                setAiOutput('Reponse IA invalide.', 'danger');
                return;
              }

              var score = typeof analysis.global_score === 'number' ? analysis.global_score : 0;
              var verdict = analysis.verdict ? analysis.verdict : 'Analyse terminee';
              var source = analysis.source ? analysis.source : 'fallback';
              var level = score >= 75 ? 'success' : (score >= 60 ? 'warning' : 'danger');
              setAiOutput('Score global: ' + score + '/100 | ' + verdict + ' | Source: ' + source, level);

              var dimensions = analysis.dimensions || {};
              var clarity = dimensions.clarity || {};
              var difficulty = dimensions.difficulty || {};
              var coverage = dimensions.coverage || {};

              var detailsHtml = '<div class="small">';
              detailsHtml += '<div><strong>Clarte:</strong> ' + (clarity.score || 0) + '/100 - ' + (clarity.comment || '') + '</div>';
              detailsHtml += '<div><strong>Difficulte:</strong> ' + (difficulty.score || 0) + '/100 - ' + (difficulty.comment || '') + '</div>';
              detailsHtml += '<div><strong>Couverture:</strong> ' + (coverage.score || 0) + '/100 - ' + (coverage.comment || '') + '</div>';
              detailsHtml += renderAiList('Risques', analysis.risks || [], 'text-danger');
              detailsHtml += renderAiList('Recommandations', analysis.recommendations || [], 'text-success');
              detailsHtml += '</div>';

              aiDetails.innerHTML = detailsHtml;
            })
            .catch(function (error) {
              setAiOutput('Erreur analyse IA: ' + String(error), 'danger');
            })
            .finally(function () {
              aiButton.disabled = false;
            });
        });
      }
    })();
  </script>
{% endblock %}
