{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block stylesheets %}
<style>
  .btn-register {
    background-color: #45a55d;
    border-color: #45a55d;
    color: #ffffff;
  }

  .btn-register:hover,
  .btn-register:focus {
    background-color: #3c9252;
    border-color: #3c9252;
    color: #ffffff;
  }
</style>
{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <form method="post">
            {% for message in app.flashes('error') %}
                <div class="alert alert-danger">{{ message }}</div>
            {% endfor %}
            {% if error %}
                <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}

            {% if app.user %}
                <div class="mb-3">
                    Vous etes connecte en tant que {{ app.user.userIdentifier }}, <a href="{{ logout_path() }}">Deconnexion</a>
                </div>
            {% endif %}

            <h1 class="h3 mb-3 font-weight-normal">Connectez-vous</h1>
            <label for="inputemail">Email</label>
            <input type="text" value="{{ last_username }}" name="email" id="inputemail" class="form-control" autocomplete="username" required autofocus>
            <label for="inputPassword">Mot de passe</label>
            <input type="password" name="password" id="inputPassword" class="form-control" autocomplete="current-password" required>
            <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">
            <div class="mb-2">
                <a href="{{ path('app_forgot_password_request') }}">Mot de passe oublie ?</a>
            </div>

            <div class="checkbox mb-3">
                <label>
                    <input type="checkbox" name="_remember_me"> Se souvenir de moi
                </label>
            </div>

            <button class="btn btn-lg w-100 btn-register" type="submit">
                Se connecter
            </button>

            <a class="btn btn-lg w-100 btn-register mt-2" href="{{ path('connect_google_start') }}">
                Continuer avec Google
            </a>
        </form>
    </div>
</div>
{% endblock %}
  {{ parent() }}
  <style>
    .auth-wrap {
      min-height: 100vh;
      display: grid;
      place-items: center;
      padding: 32px 16px;
      background: radial-gradient(circle at 20% 20%, rgba(255, 255, 255, 0.16), transparent 42%), #8f79b7;
    }

    .auth-card {
      width: 100%;
      max-width: 620px;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 22px;
      padding: 28px;
      color: #fff;
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.18);
    }

    .auth-card h1 {
      margin: 0 0 12px;
      font-size: 36px;
      line-height: 1.2;
    }

    .auth-card label {
      display: block;
      margin: 8px 0 6px;
      color: #fff;
    }

    .auth-card input[type="text"],
    .auth-card input[type="password"] {
      width: 100%;
      height: 52px;
      border: none;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.2);
      color: #fff;
      padding: 0 18px;
      margin-bottom: 8px;
    }

    .auth-card a {
      color: #ffd45f;
      font-weight: 600;
    }

    .auth-btn {
      border: none;
      border-radius: 999px;
      background: #fff;
      color: #8f79b7;
      font-weight: 700;
      padding: 10px 24px;
      margin-top: 6px;
      width: 100%;
    }

    .auth-btn + .auth-btn {
      margin-top: 10px;
    }

    .msg {
      border-radius: 10px;
      padding: 10px 12px;
      margin-bottom: 10px;
      font-size: 14px;
      background: rgba(196, 93, 93, 0.2);
      color: #ffe3e3;
      border: 1px solid rgba(196, 93, 93, 0.35);
    }
  </style>
{% endblock %}

{% block body %}
  <div class="auth-wrap">
    <div class="auth-card">
      <form method="post">
        {% for message in app.flashes('error') %}
          <div class="msg">{{ message }}</div>
        {% endfor %}

        {% if error %}
          <div class="msg">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        <h1>Connectez-vous</h1>

        <label for="inputemail">Email</label>
        <input type="text" value="{{ last_username }}" name="email" id="inputemail" autocomplete="username" required autofocus>

        <label for="inputPassword">Mot de passe</label>
        <input type="password" name="password" id="inputPassword" autocomplete="current-password" required>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <div style="margin: 6px 0 10px;">
          <a href="{{ path('app_forgot_password_request') }}">Mot de passe oublie ?</a>
        </div>

        <label style="display:flex;align-items:center;gap:8px;margin:0 0 12px;">
          <input type="checkbox" name="_remember_me" style="width:auto;height:auto;"> Se souvenir de moi
        </label>

        <button class="auth-btn" type="submit">Se connecter</button>
        <a class="auth-btn" href="{{ path('connect_google_start') }}" style="display:block;text-align:center;text-decoration:none;">Continuer avec Google</a>
      </form>
    </div>
  </div>
{% endblock %}
