{% extends 'scholar_base.html.twig' %}

{% block title %}Dashboard Parent - EduFlex{% endblock %}
{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('css/parent-dashboard.css') }}">
{% endblock %}

{% block body %}
  <div id="js-preloader" class="js-preloader">
    <div class="preloader-inner">
      <span class="dot"></span>
      <div class="dots"><span></span><span></span><span></span></div>
    </div>
  </div>

  <header class="header-area header-sticky">
    <div class="container">
      <div class="row">
        <div class="col-12">
          <nav class="main-nav">
            <a href="{{ path('app_home') }}" class="logo"><h1>Eduflex</h1></a>
            <ul class="nav">
              <li><a class="active" href="{{ path('app_parent_dashboard') }}">Dashboard</a></li>
              <li><a href="{{ path('app_forum_index_context', {'context': 'parent'}) }}">Forum</a></li>
              <li><a href="{{ logout_path() }}">Logout</a></li>
            </ul>
            <a class="menu-trigger"><span>Menu</span></a>
          </nav>
        </div>
      </div>
    </div>
  </header>

  <div class="main-banner" id="top">
    <div class="container">
      <div class="row">
        <div class="col-lg-12">
          <div class="owl-carousel owl-banner">
            <div class="item item-1">
              <div class="header-text">
                <span class="category">Espace Parent</span>
                <h2>Suivez la progression de vos enfants</h2>
                <p>Visualisez les notes de vos enfants, leurs evaluations et les informations utiles depuis un seul dashboard.</p>
                <div class="buttons">
                  <div class="main-button"><a href="{{ path('app_forum_index_context', {'context': 'parent'}) }}">Acceder forum</a></div>
                </div>
              </div>
            </div>
            <div class="item item-2">
              <div class="header-text">
                <span class="category">Communication</span>
                <h2>Restez connecte avec l'ecole</h2>
                <p>Suivez les annonces et discutez avec la communaute educative.</p>
              </div>
            </div>
            <div class="item item-3">
              <div class="header-text">
                <span class="category">Vision claire</span>
                <h2>Un espace simple et lisible</h2>
                <p>Toutes les informations importantes sont centralisees.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="services section">
    <div class="container">
      <div class="row">
        <div class="col-lg-4 col-md-6">
          <div class="service-item">
            <div class="icon"><img src="{{ asset('images/service-01.png') }}" alt="enfants"></div>
            <div class="main-content">
              <h4>Enfants suivis</h4>
              <p>Acces rapide aux donnees de vos enfants scolarises.</p>
            </div>
          </div>
        </div>
        <div class="col-lg-4 col-md-6">
          <div class="service-item">
            <div class="icon"><img src="{{ asset('images/service-02.png') }}" alt="notes"></div>
            <div class="main-content">
              <h4>Notes et evaluations</h4>
              <p>Consultez les performances recentes en un coup d'oeil.</p>
            </div>
          </div>
        </div>
        <div class="col-lg-4 col-md-6">
          <div class="service-item">
            <div class="icon"><img src="{{ asset('images/service-03.png') }}" alt="messages"></div>
            <div class="main-content">
              <h4>Messages</h4>
              <p>Restez informes des echanges importants avec l'ecole.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="section">
    <div class="container">
      <div class="row">
        <div class="col-lg-12">
          <div class="parent-panel mb-4">
              <h4 class="mb-3">Mes enfants</h4>
              {% if enfants is empty %}
                <p class="parent-empty">Aucun enfant n'est encore lie a votre compte.</p>
              {% else %}
                <div class="parent-kids">
                  {% for enfant in enfants %}
                    <span class="parent-pill">
                      {{ enfant.nom }} (ID #{{ enfant.id }})
                    </span>
                  {% endfor %}
                </div>
              {% endif %}
          </div>
        </div>

        <div class="col-lg-12">
          <div class="parent-panel">
              <h4 class="mb-3">Resultats de mes enfants</h4>
              {% set hasAnyResult = false %}
              {% for pack in resultatsParEnfant %}
                {% if pack.resultats is not empty %}
                  {% set hasAnyResult = true %}
                {% endif %}
              {% endfor %}

              {% if not hasAnyResult %}
                <p class="parent-empty">Aucun resultat disponible pour vos enfants.</p>
              {% else %}
                {% for pack in resultatsParEnfant %}
                  <div class="parent-child-header">
                    <h5 class="parent-child-title">
                      {{ pack.enfant.nom }} (ID #{{ pack.enfant.id }})
                    </h5>
                    <span class="parent-pill">
                      Moyenne: {{ pack.moyenne is null ? '-' : pack.moyenne|number_format(2, '.', ' ') ~ '/20' }}
                    </span>
                  </div>

                  {% if pack.resultats is empty %}
                    <p class="parent-empty is-spaced">Aucun resultat pour cet enfant.</p>
                  {% else %}
                    <div class="parent-table-wrap is-spaced">
                      <table class="parent-table">
                        <thead>
                          <tr>
                            <th>Examen</th>
                            <th>Cours</th>
                            <th>Date examen</th>
                            <th>Note</th>
                            <th>Appreciation</th>
                          </tr>
                        </thead>
                        <tbody>
                          {% for resultat in pack.resultats %}
                            <tr>
                              <td>{{ resultat.examen ? resultat.examen.titre : '-' }}</td>
                              <td>{{ (resultat.examen and resultat.examen.cours) ? resultat.examen.cours.titre : '-' }}</td>
                              <td>{{ (resultat.examen and resultat.examen.dateExamen) ? resultat.examen.dateExamen|date('d/m/Y') : '-' }}</td>
                              <td><span class="parent-note">{{ resultat.note }}/20</span></td>
                              <td>{{ resultat.appreciation ?: '-' }}</td>
                            </tr>
                          {% endfor %}
                        </tbody>
                      </table>
                    </div>
                  {% endif %}
                {% endfor %}
              {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script>
    (function () {
      function hidePreloader() {
        var preloader = document.getElementById('js-preloader');
        if (preloader) preloader.classList.add('loaded');
      }
      window.addEventListener('load', hidePreloader);
      setTimeout(hidePreloader, 1500);
    })();
  </script>
{% endblock %}
