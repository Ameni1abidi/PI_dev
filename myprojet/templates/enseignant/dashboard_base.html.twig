<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <title>{% block title %}EduFlex - Espace Enseignant{% endblock %}</title>

    {% block stylesheets %}
      <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700&display=swap" rel="stylesheet">
      <link rel="stylesheet" href="{{ asset('enseignant/css/enseignant.css') }}">
    {% endblock %}

    <style>
        .teacher-content {
            max-width: 1320px;
            margin: 0 auto;
        }

        .teacher-topbar-modern {
            display: grid;
            grid-template-columns: 1fr 320px;
            gap: 18px;
            align-items: start;
            margin-bottom: 22px;
        }

        .teacher-topbar-hero {
            min-height: 120px;
            border-radius: 24px;
            padding: 18px 20px;
            background: linear-gradient(130deg, #f7fbff 0%, #eaf4ff 45%, #f6ecff 100%);
            border: 1px solid rgba(70, 95, 130, 0.12);
            box-shadow: 0 12px 30px rgba(64, 76, 96, 0.12);
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .teacher-topbar-hero img {
            height: 84px;
            width: auto;
            border-radius: 12px;
            box-shadow: 0 8px 18px rgba(63, 80, 102, 0.22);
        }

        .teacher-topbar-title {
            margin: 0;
            font-size: 1.15rem;
            font-weight: 800;
            color: #253245;
        }

        .teacher-topbar-sub {
            margin-top: 4px;
            color: #50627a;
            font-size: 0.93rem;
        }

        .teacher-weather-card {
            border-radius: 24px;
            padding: 16px;
            background: linear-gradient(145deg, #101b2d 0%, #1d3557 55%, #2d4f85 100%);
            color: #f5f9ff;
            box-shadow: 0 18px 30px rgba(16, 27, 45, 0.32);
            position: relative;
            overflow: hidden;
        }

        .teacher-weather-card::after {
            content: "";
            position: absolute;
            width: 180px;
            height: 180px;
            right: -65px;
            top: -70px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(255,255,255,0.22), rgba(255,255,255,0));
        }

        .teacher-weather-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            position: relative;
            z-index: 1;
        }

        .teacher-weather-date {
            font-size: 0.84rem;
            opacity: 0.9;
            letter-spacing: 0.5px;
        }

        .teacher-weather-city {
            margin-top: 3px;
            font-size: 1rem;
            font-weight: 700;
        }

        .teacher-weather-temp {
            font-size: 2rem;
            font-weight: 900;
            line-height: 1;
            margin: 12px 0 6px;
            position: relative;
            z-index: 1;
        }

        .teacher-weather-desc {
            font-size: 0.9rem;
            opacity: 0.95;
            position: relative;
            z-index: 1;
        }

        .teacher-weather-icon {
            width: 48px;
            height: 48px;
            border-radius: 14px;
            background: rgba(255, 255, 255, 0.16);
            display: grid;
            place-items: center;
            font-size: 1.4rem;
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255, 255, 255, 0.22);
        }

        @media (max-width: 1100px) {
            .teacher-topbar-modern {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 640px) {
            .teacher-topbar-hero {
                padding: 14px;
                min-height: auto;
            }

            .teacher-topbar-hero img {
                height: 72px;
            }
        }
    </style>
</head>

<body>
<div class="teacher-shell">

    <aside class="teacher-sidebar">
        <div class="teacher-brand">
            <div class="teacher-brand-mark">EF</div>
            <div>
                <div class="teacher-brand-name">EduFlex</div>
                <div class="teacher-brand-sub">Espace enseignant</div>
            </div>
        </div>

        <div class="teacher-profile">
            <div class="teacher-avatar">ML</div>
            <div>
                <div class="teacher-name">Mme Legrand</div>
                <div class="teacher-role">Enseignante</div>
            </div>
        </div>

        <nav class="teacher-nav">
            <a href="{{ path('app_enseignant_dashboard') }}" class="{{ app.request.attributes.get('_route') == 'app_enseignant_dashboard' ? 'is-active' : '' }}">
                <span>DB</span> Tableau de bord
            </a>
            <a href="{{ path('app_forum_index_context', {'context': 'enseignant'}) }}" class="{{ app.request.attributes.get('_route') == 'app_forum_index_context' ? 'is-active' : '' }}">
                <span>FO</span> Forum
            </a>
            <a href="{{ path('app_enseignant_classes') }}" class="{{ app.request.attributes.get('_route') == 'app_enseignant_classes' ? 'is-active' : '' }}">
                <span>CL</span> Mes classes
            </a>
            <a href="{{ path('app_cours_index') }}" class="{{ app.request.attributes.get('_route') starts with 'app_cours_' ? 'is-active' : '' }}">
                <span>C</span> Cours
            </a>
            <a href="{{ path('app_ressource_index') }}" class="{{ app.request.attributes.get('_route') starts with 'app_ressource_' ? 'is-active' : '' }}">
                <span>RS</span> Ressource
            </a>
            <a href="{{ path('app_examen_index') }}" class="{{ app.request.attributes.get('_route') starts with 'app_examen_' ? 'is-active' : '' }}">
                <span>EX</span> Examens
            </a>
            <a href="{{ path('app_enseignant_evaluations') }}" class="{{ app.request.attributes.get('_route') starts with 'app_enseignant_evaluations' ? 'is-active' : '' }}">
                <span>EV</span> Evaluations
            </a>
            <a href="{{ path('app_resultat_index') }}" class="{{ app.request.attributes.get('_route') starts with 'app_resultat_' ? 'is-active' : '' }}">
                <span>RT</span> Resultats
            </a>
            <a href="{{ path('app_forum_index_context', {'context': 'enseignant'}) }}" class="{{ app.request.attributes.get('_route') == 'app_forum_index_context' ? 'is-active' : '' }}">
                <span>MS</span> Messages
            </a>
        </nav>
    </aside>

    <main class="teacher-main">
        <div class="teacher-content">
            {% set meteoDesc = weather.description|default('Indisponible') %}
            {% set meteoIcon = 'CLOUD' %}
            {% if meteoDesc == 'Ciel degage' %}
                {% set meteoIcon = 'SUN' %}
            {% elseif meteoDesc in ['Pluie', 'Averses'] %}
                {% set meteoIcon = 'RAIN' %}
            {% elseif meteoDesc in ['Orage'] %}
                {% set meteoIcon = 'STORM' %}
            {% elseif meteoDesc in ['Neige'] %}
                {% set meteoIcon = 'SNOW' %}
            {% endif %}

            <header class="teacher-topbar-modern">
                <div class="teacher-topbar-hero">
                    <img src="{{ asset('images/cours.jpg') }}" alt="Cours">
                    <div>
                        <h1 class="teacher-topbar-title">Bienvenue dans votre espace enseignant</h1>
                        <div class="teacher-topbar-sub">Suivez vos cours, vos chapitres et les statistiques en temps reel.</div>
                    </div>
                </div>

                {% if not (hideWeather|default(false)) %}
                    <div class="teacher-weather-card">
                        <div class="teacher-weather-row">
                            <div>
                                <div class="teacher-weather-date">{{ todayDate|default("now"|date("d/m/Y")) }}</div>
                                <div class="teacher-weather-city">{{ weather.city|default('Tunis') }}</div>
                            </div>
                            <div class="teacher-weather-icon">{{ meteoIcon }}</div>
                        </div>
                        <div class="teacher-weather-temp">
                            {% if weather.temperature is defined and weather.temperature is not null %}
                                {{ weather.temperature|round }} C
                            {% else %}
                                -- C
                            {% endif %}
                        </div>
                        <div class="teacher-weather-desc">{{ meteoDesc }}</div>
                    </div>
                {% endif %}
            </header>

            {% block body %}{% endblock %}
        </div>
    </main>

</div>
{% block javascripts %}{% endblock %}
</body>
</html>
