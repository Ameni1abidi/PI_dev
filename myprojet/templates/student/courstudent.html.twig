{% extends 'student/dashCours.html.twig' %}

{% block title %}Mes Cours{% endblock %}

{% block body %}
<style>
  .student-courses {
    --bg-a: #f4f8ff;
    --bg-b: #f7f4ff;
    --card: #ffffff;
    --text: #1f2937;
    --muted: #667085;
    --line: #e7eaf3;
    --primary: #2563eb;
    --primary-2: #1d4ed8;
    --success: #0f9d6d;
    --warning: #b7791f;
    padding: 26px;
    min-height: 100vh;
    background: radial-gradient(circle at 0% 0%, var(--bg-a), transparent 50%),
                radial-gradient(circle at 100% 100%, var(--bg-b), transparent 48%),
                #f7f9fc;
    color: var(--text);
    font-family: 'Manrope', sans-serif;
  }

  .student-courses .hero {
    background: linear-gradient(130deg, #0f172a, #1e3a8a);
    color: #fff;
    border-radius: 20px;
    padding: 20px;
    margin-bottom: 18px;
    box-shadow: 0 16px 30px rgba(15, 23, 42, 0.22);
  }

  .student-courses .hero-title {
    margin: 0;
    font-size: 1.65rem;
    font-weight: 800;
  }

  .student-courses .hero-sub {
    margin-top: 6px;
    opacity: .88;
    font-size: .92rem;
  }

  .student-courses .toolbar {
    display: flex;
    gap: 10px;
    margin-bottom: 18px;
  }

  .student-courses .search {
    flex: 1;
    padding: 11px 14px;
    border-radius: 12px;
    border: 1px solid #d8e0ef;
    background: #fff;
    font-size: .92rem;
  }

  .student-courses .search-btn {
    border: none;
    border-radius: 12px;
    padding: 11px 16px;
    font-weight: 700;
    color: #fff;
    background: linear-gradient(135deg, var(--primary), var(--primary-2));
    cursor: pointer;
  }

  .student-courses .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(330px, 1fr));
    gap: 18px;
  }

  .student-courses .course-card {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 18px;
    padding: 16px;
    box-shadow: 0 8px 18px rgba(15, 23, 42, 0.06);
    transition: transform .2s ease, box-shadow .2s ease;
  }

  .student-courses .course-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 24px rgba(15, 23, 42, 0.10);
  }

  .student-courses .course-head {
    display: flex;
    justify-content: space-between;
    gap: 10px;
    align-items: start;
  }

  .student-courses .course-title {
    margin: 0;
    font-size: 1.08rem;
    font-weight: 800;
    color: #0f172a;
  }

  .student-courses .date {
    font-size: .75rem;
    color: var(--muted);
    white-space: nowrap;
  }

  .student-courses .desc {
    margin: 8px 0 12px;
    color: #475569;
    font-size: .88rem;
    line-height: 1.5;
  }

  .student-courses .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 10px;
  }

  .student-courses .chip {
    font-size: .72rem;
    font-weight: 700;
    padding: 4px 8px;
    border-radius: 999px;
    background: #eef2ff;
    color: #334155;
  }

  .student-courses .progress-wrap {
    margin: 10px 0;
  }

  .student-courses .progress-head {
    display: flex;
    justify-content: space-between;
    font-size: .78rem;
    color: #475569;
    margin-bottom: 5px;
  }

  .student-courses .progress {
    height: 8px;
    border-radius: 999px;
    overflow: hidden;
    background: #e9edf6;
  }

  .student-courses .progress > span {
    display: block;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, #0ea5e9, #22c55e);
  }

  .student-courses .cert {
    margin: 10px 0 12px;
    padding: 10px;
    border-radius: 12px;
    border: 1px dashed #cfd7e7;
    background: #f8faff;
  }

  .student-courses .cert-note {
    margin-top: 6px;
    font-size: .78rem;
    color: var(--warning);
  }

  .student-courses .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 10px;
  }

  .student-courses .btn {
    text-decoration: none;
    border-radius: 10px;
    padding: 8px 12px;
    font-size: .8rem;
    font-weight: 700;
  }

  .student-courses .btn-main { background: linear-gradient(135deg, #2563eb, #1d4ed8); color: #fff; }
  .student-courses .btn-soft { background: #eef2ff; color: #1d4ed8; }
  .student-courses .btn-pink { background: #ffe8f1; color: #9d174d; }
  .student-courses .btn-muted { background: #e5e7eb; color: #4b5563; }

  .student-courses .chap-list {
    margin-top: 10px;
    display: grid;
    gap: 10px;
  }

  .student-courses .chap {
    border: 1px solid #e5eaf4;
    border-radius: 14px;
    padding: 11px;
    background: #fbfdff;
  }

  .student-courses .chap-title {
    margin: 0 0 5px;
    font-size: .9rem;
    font-weight: 700;
    color: #1f2937;
  }

  .student-courses .chap-meta {
    font-size: .78rem;
    color: #556070;
    margin-bottom: 4px;
  }

  .student-courses .empty {
    text-align: center;
    padding: 24px;
    border-radius: 14px;
    background: #fff;
    border: 1px dashed #d7deeb;
    color: #6b7280;
  }

  @media (max-width: 720px) {
    .student-courses { padding: 14px; }
    .student-courses .toolbar { flex-direction: column; }
    .student-courses .search-btn { width: 100%; }
    .student-courses .grid { grid-template-columns: 1fr; }
  }
</style>

<div class="student-courses">
  <section class="hero">
    <h2 class="hero-title">Mes Cours</h2>
    <div class="hero-sub">Suivez vos chapitres, votre progression et l'acces au certificat dans un seul espace.</div>
  </section>

  <form method="get" class="toolbar">
    <input class="search" type="text" name="search" placeholder="Rechercher un cours..." value="{{ app.request.query.get('search') }}">
    <button class="search-btn" type="submit">Rechercher</button>
  </form>

  {% for label, messages in app.flashes %}
    {% for message in messages %}
      <div style="margin-bottom:12px; padding:10px 14px; border-radius:12px; font-weight:600;
        background:{% if label == 'success' %}#e8fff0{% elseif label == 'warning' %}#fff7e0{% else %}#ffe9e9{% endif %};
        color:{% if label == 'success' %}#1c6b3a{% elseif label == 'warning' %}#7a5b00{% else %}#8a1f1f{% endif %};">
        {{ message }}
      </div>
    {% endfor %}
  {% endfor %}

  {% if cours is not empty %}
    <div class="grid">
      {% for cour in cours %}
        {% set prog = courseProgress[cour.id]|default({'completed': 0, 'total': 0, 'percent': 0}) %}
        {% set cert = certificateAccess[cour.id]|default({'eligible': false, 'remainingMinutes': 0, 'spentMinutes': 0, 'requiredMinutes': 0, 'remainingChapitres': 0}) %}
        {% set badges = badgesByCours[cour.id]|default([]) %}

        <article class="course-card">
          <div class="course-head">
            <h3 class="course-title">{{ cour.titre }}</h3>
            <div class="date">{{ cour.dateCreation ? cour.dateCreation|date('d/m/Y') : 'N/A' }}</div>
          </div>

          {% if badges is not empty %}
            <div class="chips">
              {% for badge in badges %}
                <span class="chip" style="
                  {% if badge.code == 'nouveau' %}background:#dcfce7;color:#166534;
                  {% elseif badge.code == 'a_la_une' %}background:#fee2e2;color:#991b1b;
                  {% elseif badge.code == 'tres_populaire' %}background:#fff7d6;color:#92400e;
                  {% elseif badge.code == 'en_tendance' %}background:#ede9fe;color:#5b21b6;
                  {% else %}background:#e5e7eb;color:#374151;
                  {% endif %}
                ">
                  {{ badge.label }}
                </span>
              {% endfor %}
            </div>
          {% endif %}

          {% if cour.description %}
            <p class="desc">{{ cour.description|slice(0, 165) }}{% if cour.description|length > 165 %}...{% endif %}</p>
          {% endif %}

          <div class="chips">
            <span class="chip">Chapitres: {{ cour.chapitres|length }}</span>
          </div>

          <div class="progress-wrap">
            <div class="progress-head">
              <span>Progression</span>
              <span>{{ prog.completed }}/{{ prog.total }} ({{ prog.percent }}%)</span>
            </div>
            <div class="progress">
              <span style="width:{{ prog.percent }}%"></span>
            </div>
          </div>

          <div class="cert">
            {% if cert.eligible %}
              <a href="{{ path('eleve_cours_show', {'id': cour.id}) }}" class="btn btn-main">Certificat disponible</a>
            {% else %}
              <span class="btn btn-muted">Certificat bloque</span>
              <div class="cert-note">
                {% if cert.remainingChapitres > 0 %}
                  Terminez d'abord {{ cert.remainingChapitres }} chapitre(s).
                {% else %}
                  Reste {{ cert.remainingMinutes }} min ({{ cert.spentMinutes }}/{{ cert.requiredMinutes }} min)
                {% endif %}
              </div>
            {% endif %}
          </div>

          <div class="actions">
            <a href="{{ path('eleve_cours_show', {'id': cour.id}) }}" class="btn btn-main">Voir les chapitres</a>
          </div>

          {% if cour.chapitres is not empty %}
            <div class="chap-list">
              {% for chap in cour.chapitres|sort((a, b) => a.ordre <=> b.ordre) %}
                {% set meta = chapterUi[chap.id]|default({'unlocked': true, 'completed': false, 'blockedMessage': null, 'spentMinutes': 0, 'timeBadge': 'En cours'}) %}
                {% set ressourcesCount = chap.ressources|length %}

                <div class="chap">
                  <h4 class="chap-title">{{ chap.ordre }}. {{ chap.titre }}</h4>
                  <div class="chap-meta">Duree: {{ chap.dureeEstimee }} min | Temps passe: {{ meta.spentMinutes }} min</div>
                  <div class="chap-meta">Type: {% if chap.typeContenu == 'fichier' %}PDF{% else %}{{ chap.typeContenu }}{% endif %}</div>
                  <div class="chap-meta">Statut: {{ meta.completed ? 'Termine' : 'En cours' }} | Badge temps: {{ meta.timeBadge }}</div>

                  {% if chap.typeContenu == 'fichier' and chap.contenuFichier %}
                    <a href="{{ asset('uploads/' ~ chap.contenuFichier) }}" target="_blank" class="btn btn-soft">Telecharger PDF</a>
                  {% elseif chap.typeContenu == 'video' and chap.videoUrl %}
                    <a href="{{ chap.videoUrl }}" target="_blank" class="btn btn-soft">Voir Video</a>
                  {% elseif chap.typeContenu == 'texte' and chap.contenuTexte %}
                    <div class="chap-meta">{{ chap.contenuTexte|slice(0, 120) }}{% if chap.contenuTexte|length > 120 %}...{% endif %}</div>
                  {% endif %}

                  <div class="actions" style="margin-top:8px; margin-bottom:0;">
                    {% if ressourcesCount > 0 %}
                      <a href="{{ path('eleve_chapitre_ressources', {'id': chap.id}) }}" class="btn btn-pink">Ressources ({{ ressourcesCount }})</a>
                    {% endif %}

                    {% if meta.unlocked %}
                      <a href="{{ path('eleve_chapitre_ressources', {'id': chap.id}) }}" class="btn btn-main">Voir resume</a>
                    {% else %}
                      <span class="btn btn-muted">Chapitre verrouille</span>
                      {% if meta.blockedMessage %}
                        <span class="chap-meta" style="margin-bottom:0; color:#92400e;">{{ meta.blockedMessage }}</span>
                      {% endif %}
                    {% endif %}
                  </div>
                </div>
              {% endfor %}
            </div>
          {% else %}
            <div class="empty" style="margin-top:10px;">Aucun chapitre pour ce cours.</div>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  {% else %}
    <div class="empty">Aucun cours disponible pour le moment.</div>
  {% endif %}
</div>
{% endblock %}
