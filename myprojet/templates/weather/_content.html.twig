<div style="padding:24px; font-family:'Manrope', sans-serif;">
  <div style="max-width:980px; margin:0 auto;">
    <div style="border-radius:22px; padding:22px; margin-bottom:16px; background:linear-gradient(130deg,#0f172a 0%,#1d4ed8 55%,#0ea5e9 100%); color:#fff; box-shadow:0 18px 34px rgba(30,64,175,0.28);">
      <div style="display:flex; justify-content:space-between; align-items:center; gap:16px; flex-wrap:wrap;">
        <div>
          <div style="font-size:0.84rem; opacity:.85; letter-spacing:.08em; text-transform:uppercase;">Weather Center</div>
          <h2 style="margin:4px 0 0; font-size:1.9rem; line-height:1.1;">Meteo en direct</h2>
        </div>
        {% if weather %}
          <div style="font-size:0.95rem; text-align:right;">
            <div style="font-weight:800; font-size:1.05rem;">{{ weather.name }}{% if weather.country is defined and weather.country %}, {{ weather.country }}{% endif %}</div>
            <div style="opacity:.9;">{{ weather.localtime ?: 'Mise a jour en cours' }}</div>
          </div>
        {% endif %}
      </div>
    </div>

    <form method="get" style="display:flex; gap:10px; flex-wrap:wrap; margin-bottom:16px;">
      <input
        type="text"
        name="city"
        value="{{ city }}"
        placeholder="Entrer une ville"
        style="padding:12px 14px; border-radius:12px; border:1px solid #bfdbfe; min-width:250px; background:#fff; box-shadow:0 8px 18px rgba(148,163,184,0.2);"
      >
      <button type="submit" style="border:none; padding:12px 16px; border-radius:12px; background:#1d4ed8; color:#fff; font-weight:800; box-shadow:0 8px 18px rgba(29,78,216,0.32);">
        Rechercher
      </button>
    </form>

    {% if weather %}
      <div style="background:#fff; border:1px solid #dbeafe; border-radius:20px; padding:18px; box-shadow:0 14px 30px rgba(15,23,42,0.08);">
        <div style="display:flex; justify-content:space-between; align-items:center; gap:14px; flex-wrap:wrap; margin-bottom:12px;">
          <div>
            <div style="font-size:1.25rem; font-weight:900; color:#0f172a;">{{ weather.name }}</div>
            <div style="color:#1e40af; font-weight:700;">{{ weather.weather[0].description }}</div>
          </div>
          {% if weather.weather[0].icon is defined and weather.weather[0].icon %}
            <img src="{{ weather.weather[0].icon }}" alt="Icone meteo" style="width:64px; height:64px;">
          {% endif %}
        </div>

        <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(160px,1fr)); gap:10px;">
          <div style="background:#eff6ff; border:1px solid #bfdbfe; border-radius:12px; padding:12px;">
            <div style="font-size:0.8rem; color:#475569;">Temperature</div>
            <div style="font-size:1.35rem; font-weight:900; color:#0f172a;">{{ weather.main.temp }} deg C</div>
          </div>
          <div style="background:#f0fdf4; border:1px solid #bbf7d0; border-radius:12px; padding:12px;">
            <div style="font-size:0.8rem; color:#475569;">Ressenti</div>
            <div style="font-size:1.35rem; font-weight:900; color:#0f172a;">{{ weather.main.feels_like }} deg C</div>
          </div>
          <div style="background:#fffbeb; border:1px solid #fde68a; border-radius:12px; padding:12px;">
            <div style="font-size:0.8rem; color:#475569;">Humidite</div>
            <div style="font-size:1.35rem; font-weight:900; color:#0f172a;">{{ weather.main.humidity }} %</div>
          </div>
          <div style="background:#f5f3ff; border:1px solid #ddd6fe; border-radius:12px; padding:12px;">
            <div style="font-size:0.8rem; color:#475569;">Vent</div>
            <div style="font-size:1.35rem; font-weight:900; color:#0f172a;">{{ weather.wind_kph|default(0) }} km/h</div>
          </div>
        </div>
      </div>

      {% if weather.forecast_days is defined and weather.forecast_days is not empty %}
        <div style="margin-top:14px; background:#fff; border:1px solid #dbeafe; border-radius:20px; padding:16px; box-shadow:0 14px 30px rgba(15,23,42,0.08);">
          <div style="font-size:1.05rem; font-weight:900; color:#0f172a; margin-bottom:6px;">Previsions de la semaine</div>
          {% if weather.forecast_days|length < 7 %}
            <div style="font-size:0.8rem; color:#475569; margin-bottom:8px;">Ton plan API retourne {{ weather.forecast_days|length }} jour(s) de prevision.</div>
          {% endif %}
          <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(130px,1fr)); gap:10px;">
            {% for day in weather.forecast_days %}
              <div style="background:#f8fafc; border:1px solid #e2e8f0; border-radius:12px; padding:10px;">
                <div style="font-size:0.8rem; color:#475569; margin-bottom:6px;">{{ day.date|date('D d/m') }}</div>
                {% if day.icon %}
                  <img src="{{ day.icon }}" alt="Icone meteo" style="width:40px; height:40px;">
                {% endif %}
                <div style="font-size:0.86rem; color:#1f2937; font-weight:700; margin-top:4px;">{{ day.max_temp }} / {{ day.min_temp }} deg C</div>
                <div style="font-size:0.78rem; color:#475569; margin-top:2px;">{{ day.description }}</div>
              </div>
            {% endfor %}
          </div>
        </div>
      {% endif %}
    {% else %}
      <div style="background:#fff; border:1px solid #fecaca; color:#991b1b; border-radius:14px; padding:16px;">
        Impossible de recuperer la meteo pour cette ville.
        {% if weather_error %}
          <br>{{ weather_error }}
        {% else %}
          <br>Verifie la cle API ou le nom de la ville.
        {% endif %}
      </div>
    {% endif %}
  </div>
</div>
